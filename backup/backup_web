      color: rgba(100,220,140,.8);
      font-weight: bold;
      font-size: .82rem;
    }

    /* Blinking cursor */
    .cursor {
      display: inline-block;
      width: 7px; height: .9em;
      background: rgba(100,220,140,.8);
      vertical-align: middle;
      margin-left: 2px;
      animation: blink .9s step-start infinite;
    }
    @keyframes blink {
      0%,100% { opacity: 1; }
      50%      { opacity: 0; }
    }
    /* ══════════════════════════════════════
       ANNOUNCEMENT TICKER BAR
    ══════════════════════════════════════ */
    #ticker-bar {
      position: relative;
      z-index: 1100;
      background: linear-gradient(90deg, var(--primary) 0%, var(--primary-lt) 50%, var(--sky) 100%);
      color: #fff;
      height: 36px;
      display: flex;
      align-items: center;
      overflow: hidden;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .06em;
    }
    #ticker-bar .ticker-label {
      flex-shrink: 0;
      background: rgba(0,0,0,.18);
      height: 100%;
      padding: 0 18px;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      border-right: 1px solid rgba(255,255,255,.18);
      text-transform: uppercase;
    }
    #ticker-bar .ticker-label::before {
      content: '';
      display: inline-block;
      width: 7px; height: 7px;
      background: var(--accent-lt);
      border-radius: 50%;
      animation: ticker-blink 1.2s ease infinite;
    }
    @keyframes ticker-blink {
      0%,100% { opacity: 1; }
      50%      { opacity: .25; }
    }
    .ticker-track-wrap {
      flex: 1;
      overflow: hidden;
      height: 100%;
      display: flex;
      align-items: center;
    }
    .ticker-track {
      display: flex;
      gap: 0;
      animation: ticker-scroll 28s linear infinite;
      white-space: nowrap;
    }
    .ticker-track:hover { animation-play-state: paused; }
    .ticker-item {
      padding: 0 36px;
      opacity: .9;
      position: relative;
    }
    .ticker-item + .ticker-item::before {
      content: '◆';
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      font-size: .45rem;
      color: var(--accent-lt);
    }
    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    #ticker-bar .ticker-close {
      flex-shrink: 0;
      padding: 0 14px;
      height: 100%;
      background: none;
      border: none;
      border-left: 1px solid rgba(255,255,255,.15);
      color: rgba(255,255,255,.6);
      cursor: pointer;
      font-size: .8rem;
      transition: background .15s, color .15s;
    }
    #ticker-bar .ticker-close:hover {
      background: rgba(0,0,0,.12);
      color: #fff;
    }

    /* ══════════════════════════════════════
       NAV MODERN PILL INDICATOR
    ══════════════════════════════════════ */
    #navbar {
      transition: box-shadow .3s ease, background .3s ease;
    }
    .nav-links a {
      position: relative;
    }
    .nav-links a.nav-active::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 50%;
      transform: translateX(-50%);
      width: 4px; height: 4px;
      background: var(--primary);
      border-radius: 50%;
    }

    /* ══════════════════════════════════════
       HERO ENHANCEMENTS
    ══════════════════════════════════════ */
    /* Animated gradient orbs */
    .hero-orb {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      mix-blend-mode: screen;
      z-index: 1;
    }
    .hero-orb-1 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(14,165,233,.2), transparent 65%);
      top: -100px; right: -80px;
      animation: orbFloat1 8s ease-in-out infinite;
    }
    .hero-orb-2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(245,158,11,.14), transparent 65%);
      bottom: 60px; left: -60px;
      animation: orbFloat2 10s ease-in-out infinite;
    }
    @keyframes orbFloat1 {
      0%,100% { transform: translate(0,0); }
      50%      { transform: translate(-30px, 30px); }
    }
    @keyframes orbFloat2 {
      0%,100% { transform: translate(0,0); }
      50%      { transform: translate(20px, -20px); }
    }

    /* Grid pattern overlay on hero */
    .hero-grid {
      position: absolute; inset: 0;
      z-index: 1;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse at center, rgba(0,0,0,.5) 0%, transparent 70%);
    }

    /* ══════════════════════════════════════
       SECTION WAVE DIVIDER
    ══════════════════════════════════════ */
