<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SD Negeri 2 Pegundungan| Sekolah Dasar</title>
  <meta name="description" content="SD Negeri 2 Pegundungan – Sekolah Dasar di dusun srandil, desa pegundungan, kec. pejawaran, banjarnegara Jawa Tengah. Membentuk generasi unggul, cerdas, kreatif, dan berakhlak mulia.">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

  <style>
    /* ══════════════════════════════════════
       DESIGN TOKENS
    ══════════════════════════════════════ */
    :root {
      --primary:       #1a3a6e;
      --primary-lt:    #2557a7;
      --sky:           #0ea5e9;
      --accent:        #f59e0b;
      --accent-lt:     #fcd34d;
      --dark:          #0c1830;
      --text:          #1e293b;
      --muted:         #64748b;
      --bg-soft:       #f0f7ff;
      --bg-section:    #f8fafc;
      --shadow-sm:     0 4px 24px rgba(26,58,110,.08);
      --shadow-md:     0 12px 40px rgba(26,58,110,.14);
      --shadow-lg:     0 24px 60px rgba(26,58,110,.18);
      --r:             20px;
      --r-sm:          12px;
      --nav-h:         70px;
    }

    /* ══════════════════════════════════════
       RESET & BASE
    ══════════════════════════════════════ */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: calc(var(--nav-h) + 12px);
    }

    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      color: var(--text);
      line-height: 1.7;
      background: #fff;
      overflow-x: hidden;
    }

    img { max-width: 100%; height: auto; display: block; }
    a { text-decoration: none; }

    /* ══════════════════════════════════════
       SCROLL ANIMATIONS  (GPU-safe only)
    ══════════════════════════════════════ */
    @media (prefers-reduced-motion: no-preference) {
      .aos {
        opacity: 0;
        transform: translateY(36px);
        transition: opacity .65s cubic-bezier(.22,1,.36,1),
                    transform .65s cubic-bezier(.22,1,.36,1);
        will-change: opacity, transform;
      }
      .aos.d1 { transition-delay: .10s }
      .aos.d2 { transition-delay: .20s }
      .aos.d3 { transition-delay: .30s }
      .aos.d4 { transition-delay: .40s }

      .aos.visible {
        opacity: 1;
        transform: translateY(0);
        will-change: auto;
      }

      /* fade-up variant for cards that scale in */
      .aos-scale {
        opacity: 0;
        transform: scale(.94) translateY(24px);
        transition: opacity .55s cubic-bezier(.22,1,.36,1),
                    transform .55s cubic-bezier(.22,1,.36,1);
        will-change: opacity, transform;
      }
      .aos-scale.visible {
        opacity: 1;
        transform: scale(1) translateY(0);
        will-change: auto;
      }
    }

    /* ══════════════════════════════════════
       NAVIGATION
    ══════════════════════════════════════ */
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      height: var(--nav-h);
      background: rgba(255,255,255,.96);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(26,58,110,.07);
      transition: box-shadow .3s ease;
    }
    nav.scrolled { box-shadow: var(--shadow-sm); }

    .nav-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 clamp(16px, 3vw, 40px);
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    /* Logo */
    .logo { display:flex; align-items:center; gap:12px; }
    .logo-icon {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--primary), var(--sky));
      border-radius: 11px;
      display: flex; align-items:center; justify-content:center;
      font-size: 1.4rem;
      flex-shrink: 0;
    }
    .logo-text { line-height: 1.2; }
    .logo-text strong {
      font-family: 'Playfair Display', serif;
      font-size: clamp(.95rem, 2vw, 1.15rem);
      color: var(--primary);
      display: block;
    }
    .logo-text small {
      font-size: .7rem;
      color: var(--muted);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .05em;
    }

    /* Desktop links */
    .nav-links {
      display: flex;
      align-items: center;
      gap: 4px;
      list-style: none;
    }
    .nav-links a {
      color: var(--text);
      font-weight: 600;
      font-size: .875rem;
      padding: 7px 12px;
      border-radius: 8px;
      transition: background .18s, color .18s;
      white-space: nowrap;
    }
    .nav-links a:hover { background: var(--bg-soft); color: var(--primary); }
    .nav-links .nav-cta {
      background: var(--primary);
      color: #fff !important;
      padding: 9px 20px;
      border-radius: 50px;
      margin-left: 6px;
    }
    .nav-links .nav-cta:hover {
      background: var(--primary-lt) !important;
      color: #fff !important;
    }

    /* Hamburger */
    .hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 40px; height: 40px;
      background: none;
      border: none;
      cursor: pointer;
      border-radius: 8px;
      padding: 6px;
      transition: background .2s;
    }
    .hamburger:hover { background: var(--bg-soft); }
    .hamburger span {
      display: block;
      height: 2px;
      background: var(--dark);
      border-radius: 2px;
      transition: transform .3s ease, opacity .3s ease, width .3s ease;
    }
    .hamburger span:nth-child(1) { width: 24px; }
    .hamburger span:nth-child(2) { width: 18px; }
    .hamburger span:nth-child(3) { width: 24px; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); width: 24px; }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); width: 24px; }

    /* Mobile dropdown */
    .mobile-menu {
      position: fixed;
      top: var(--nav-h);
      left: 0; right: 0;
      background: #fff;
      border-bottom: 1px solid rgba(26,58,110,.08);
      box-shadow: 0 20px 40px rgba(0,0,0,.1);
      padding: 16px;
      display: none;
      flex-direction: column;
      gap: 4px;
      z-index: 999;
      /* animation handled by JS toggling .open class */
      transform-origin: top;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      color: var(--text);
      font-weight: 600;
      font-size: .95rem;
      padding: 12px 16px;
      border-radius: 10px;
      transition: background .15s, color .15s;
    }
    .mobile-menu a:hover { background: var(--bg-soft); color: var(--primary); }
    .mobile-menu .mob-cta {
      background: var(--primary);
      color: #fff !important;
      text-align: center;
      margin-top: 8px;
      border-radius: 50px;
    }
    .mobile-menu .mob-cta:hover { background: var(--primary-lt) !important; }

    /* ══════════════════════════════════════
       HERO
    ══════════════════════════════════════ */
    .hero {
      min-height: 100svh;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      overflow: hidden;
      color: #fff;
    }

    .hero-bg {
      position: absolute; inset: 0;
      background:
        linear-gradient(160deg,
          rgba(12,24,48,.90) 0%,
          rgba(26,58,110,.80) 55%,
          rgba(14,165,233,.55) 100%),
        url('https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=1920&q=75&auto=format')
          center/cover no-repeat;
      z-index: 0;
    }

    /* Decorative blob */
    .hero-glow {
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(245,158,11,.12), transparent 70%);
      top: 10%; right: -100px;
      pointer-events: none;
      z-index: 1;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 860px;
      padding: 0 clamp(16px, 5vw, 48px);
      padding-bottom: 120px; /* space for stats bar */
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(245,158,11,.18);
      border: 1px solid rgba(245,158,11,.4);
      color: var(--accent-lt);
      padding: 8px 22px;
      border-radius: 50px;
      font-size: .8rem;
      font-weight: 700;
      letter-spacing: .07em;
      text-transform: uppercase;
      margin-bottom: 28px;
      animation: heroFade .8s .1s ease both;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.6rem, 8vw, 5.5rem);
      font-weight: 900;
      line-height: 1.08;
      letter-spacing: -.02em;
      margin-bottom: 10px;
      animation: heroFade .8s .22s ease both;
    }
    .hero h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--accent-lt));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: clamp(1rem, 2.8vw, 1.3rem);
      color: rgba(255,255,255,.82);
      max-width: 640px;
      margin: 20px auto 40px;
      animation: heroFade .8s .34s ease both;
    }

    .hero-btns {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
      animation: heroFade .8s .46s ease both;
    }

    /* Stats strip */
    .hero-stats {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      z-index: 2;
      background: linear-gradient(to top, rgba(0,0,0,.55), transparent);
      padding: clamp(20px,4vw,36px) clamp(16px,5vw,48px);
      display: flex;
      justify-content: center;
      align-items: center;
      gap: clamp(24px, 6vw, 80px);
      animation: heroFade .8s .6s ease both;
    }
    .stat-item { text-align: center; }
    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 5vw, 3rem);
      font-weight: 800;
      color: var(--accent-lt);
      line-height: 1;
    }
    .stat-label {
      font-size: clamp(.7rem, 1.6vw, .85rem);
      color: rgba(255,255,255,.75);
      font-weight: 600;
      margin-top: 4px;
    }

    @keyframes heroFade {
      from { opacity: 0; transform: translateY(-16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Scroll cue */
    .scroll-cue {
      position: absolute;
      bottom: 90px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      color: rgba(255,255,255,.5);
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      animation: scrollCueFade 1s 1.2s ease both;
    }
    .scroll-cue-mouse {
      width: 22px; height: 36px;
      border: 2px solid rgba(255,255,255,.35);
      border-radius: 11px;
      position: relative;
    }
    .scroll-cue-mouse::after {
      content: '';
      position: absolute;
      top: 5px;
      left: 50%;
      transform: translateX(-50%);
      width: 4px; height: 7px;
      background: rgba(255,255,255,.6);
      border-radius: 2px;
      animation: scrollDot 1.6s ease infinite;
    }
    @keyframes scrollDot {
      0%,100% { top:5px; opacity:1 }
      60%      { top:18px; opacity:.2 }
    }
    @keyframes scrollCueFade {
      from { opacity:0 }
      to   { opacity:1 }
    }

    /* ══════════════════════════════════════
       BUTTONS (reusable)
    ══════════════════════════════════════ */
    .btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, var(--accent), var(--accent-lt));
      color: var(--dark);
      font-weight: 700;
      font-size: clamp(.9rem, 2vw, 1.05rem);
      padding: 15px 38px;
      border-radius: 50px;
      box-shadow: 0 8px 28px rgba(245,158,11,.35);
      transition: transform .22s ease, box-shadow .22s ease;
    }
    .btn-gold:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(245,158,11,.5);
    }
    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,.1);
      color: #fff;
      font-weight: 600;
      font-size: clamp(.9rem, 2vw, 1.05rem);
      padding: 15px 38px;
      border-radius: 50px;
      border: 1.5px solid rgba(255,255,255,.3);
      backdrop-filter: blur(4px);
      transition: background .22s ease, border-color .22s ease;
    }
    .btn-outline:hover {
      background: rgba(255,255,255,.2);
      border-color: rgba(255,255,255,.55);
    }

    /* ══════════════════════════════════════
       SHARED SECTION STYLES
    ══════════════════════════════════════ */
    section { padding: clamp(64px, 10vw, 120px) 0; }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 clamp(16px, 4vw, 40px);
    }
    .bg-soft    { background: var(--bg-section); }
    .bg-primary { background: var(--primary); }

    .sec-eyebrow {
      display: inline-block;
      background: var(--bg-soft);
      color: var(--primary-lt);
      padding: 5px 16px;
      border-radius: 50px;
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .sec-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 5vw, 2.9rem);
      font-weight: 800;
      color: var(--primary);
      line-height: 1.2;
      margin-bottom: clamp(36px, 5vw, 64px);
    }
    .sec-title.center { text-align: center; }
    .sec-title span { color: var(--sky); }

    /* ══════════════════════════════════════
       ABOUT
    ══════════════════════════════════════ */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(36px, 6vw, 80px);
      align-items: center;
    }
    .about-img-wrap {
      position: relative;
      border-radius: var(--r);
      overflow: visible;
    }
    .about-img-wrap img {
      width: 100%;
      height: clamp(280px, 40vw, 480px);
      object-fit: cover;
      border-radius: var(--r);
      box-shadow: var(--shadow-lg);
    }
    .about-float {
      position: absolute;
      bottom: -20px;
      right: -20px;
      background: #fff;
      border-radius: 16px;
      padding: 18px 24px;
      box-shadow: var(--shadow-md);
      text-align: center;
    }
    .about-float .num {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 800;
      color: var(--primary);
      line-height: 1;
    }
    .about-float p { font-size: .78rem; color: var(--muted); font-weight: 600; margin-top: 4px; }

    .about-lead {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--muted);
      line-height: 1.9;
      margin-bottom: 32px;
    }
    .vm-stack { display: flex; flex-direction: column; gap: 16px; }
    .vm-card {
      background: var(--bg-soft);
      border-left: 4px solid var(--primary);
      border-radius: 0 var(--r-sm) var(--r-sm) 0;
      padding: 18px 22px;
    }
    .vm-card h4 {
      font-size: .75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .07em;
      color: var(--primary);
      margin-bottom: 6px;
    }
    .vm-card p { font-size: .92rem; color: var(--muted); }

    /* ══════════════════════════════════════
       PROGRAM CARDS
    ══════════════════════════════════════ */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
      gap: 24px;
    }
    .prog-card {
      background: #fff;
      border-radius: var(--r);
      padding: clamp(24px, 4vw, 36px);
      box-shadow: var(--shadow-sm);
      border: 1px solid rgba(26,58,110,.06);
      position: relative;
      overflow: hidden;
      transition: transform .28s cubic-bezier(.22,1,.36,1),
                  box-shadow .28s cubic-bezier(.22,1,.36,1);
    }
    .prog-card::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--primary), var(--sky));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .3s ease;
    }
    .prog-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-md); }
    .prog-card:hover::after { transform: scaleX(1); }
    .prog-card .card-icon {
      width: 58px; height: 58px;
      background: linear-gradient(135deg, var(--bg-soft), rgba(14,165,233,.1));
      border-radius: 14px;
      display: flex; align-items:center; justify-content:center;
      font-size: 1.8rem;
      margin-bottom: 22px;
    }
    .prog-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: var(--primary);
      margin-bottom: 10px;
    }
    .prog-card p { font-size: .9rem; color: var(--muted); }

    /* ══════════════════════════════════════
       FACILITIES
    ══════════════════════════════════════ */
    .fac-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
      gap: 20px;
    }
    .fac-card {
      display: flex;
      align-items: center;
      gap: 18px;
      background: #fff;
      border-radius: var(--r-sm);
      padding: 22px 24px;
      box-shadow: var(--shadow-sm);
      border: 1px solid rgba(26,58,110,.06);
      transition: transform .25s ease, box-shadow .25s ease;
    }
    .fac-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
    .fac-ico {
      width: 52px; height: 52px;
      background: linear-gradient(135deg, var(--bg-soft), rgba(14,165,233,.12));
      border-radius: 12px;
      display: flex; align-items:center; justify-content:center;
      font-size: 1.5rem;
      flex-shrink: 0;
    }
    .fac-card h3 { font-weight: 700; font-size: .97rem; color: var(--text); margin-bottom: 3px; }
    .fac-card p  { font-size: .82rem; color: var(--muted); }

    /* ══════════════════════════════════════
       EXTRACURRICULAR
    ══════════════════════════════════════ */
    .ekstra-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
    }
    .ekstra-chip {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #fff;
      border: 1.5px solid rgba(26,58,110,.12);
      border-radius: 50px;
      padding: 13px 24px;
      font-weight: 600;
      font-size: clamp(.85rem, 1.8vw, .95rem);
      color: var(--text);
      cursor: default;
      transition: background .2s, border-color .2s, color .2s, transform .2s;
    }
    .ekstra-chip:hover {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary);
      transform: translateY(-3px);
    }
    .ekstra-chip span { font-size: 1.25rem; }

    /* ══════════════════════════════════════
       GALLERY
    ══════════════════════════════════════ */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
      gap: 18px;
    }
    .gallery-item {
      position: relative;
      overflow: hidden;
      border-radius: var(--r);
      aspect-ratio: 4 / 3;
    }
    .gallery-item img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform .5s cubic-bezier(.22,1,.36,1);
    }
    .gallery-item:hover img { transform: scale(1.08); }
    .gallery-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(12,24,48,.72), transparent 55%);
      opacity: 0;
      transition: opacity .3s ease;
      display: flex;
      align-items: flex-end;
      padding: 18px;
    }
    .gallery-item:hover .gallery-overlay { opacity: 1; }
    .gallery-overlay span {
      color: #fff;
      font-weight: 600;
      font-size: .85rem;
    }

    /* ══════════════════════════════════════
       TESTIMONIALS
    ══════════════════════════════════════ */
    .testi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
      gap: 24px;
    }
    .testi-card {
      background: #fff;
      border-radius: var(--r);
      padding: clamp(24px, 4vw, 36px);
      box-shadow: var(--shadow-sm);
      border: 1px solid rgba(26,58,110,.06);
      position: relative;
    }
    .testi-card::before {
      content: '\201C';
      font-family: 'Playfair Display', serif;
      font-size: 5rem;
      color: var(--primary);
      opacity: .07;
      position: absolute;
      top: 0; left: 20px;
      line-height: 1;
    }
    .testi-stars { display:flex; gap:3px; margin-bottom: 14px; }
    .testi-stars i { color: var(--accent); font-size: .9rem; }
    .testi-text {
      font-style: italic;
      color: var(--text);
      font-size: .97rem;
      line-height: 1.8;
      margin-bottom: 24px;
    }
    .testi-author { display:flex; align-items:center; gap:14px; }
    .testi-avatar {
      width: 46px; height: 46px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--sky));
      display:flex; align-items:center; justify-content:center;
      color: #fff;
      font-weight: 700;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .testi-info h4 { font-weight: 700; font-size: .92rem; color: var(--text); }
    .testi-info p  { font-size: .78rem; color: var(--muted); }

    /* ══════════════════════════════════════
       CTA / PPDB
    ══════════════════════════════════════ */
    .cta-section {
      background: linear-gradient(135deg, var(--dark) 0%, var(--primary) 50%, #1e6da8 100%);
      position: relative;
      overflow: hidden;
    }
    .cta-section::before,
    .cta-section::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
    }
    .cta-section::before {
      width: 500px; height: 500px;
      background: rgba(255,255,255,.03);
      top: -200px; right: -100px;
    }
    .cta-section::after {
      width: 350px; height: 350px;
      background: rgba(245,158,11,.06);
      bottom: -120px; left: -80px;
    }
    .cta-inner {
      position: relative;
      z-index: 1;
      text-align: center;
      color: #fff;
    }
    .cta-tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(245,158,11,.18);
      border: 1px solid rgba(245,158,11,.35);
      color: var(--accent-lt);
      padding: 7px 20px;
      border-radius: 50px;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .06em;
      text-transform: uppercase;
      margin-bottom: 22px;
    }
    .cta-inner .sec-title {
      color: #fff;
      margin-bottom: 14px;
    }
    .cta-inner p {
      font-size: clamp(.95rem, 2.2vw, 1.15rem);
      color: rgba(255,255,255,.8);
      max-width: 560px;
      margin: 0 auto 40px;
    }

    /* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ */
    footer {
      background: var(--dark);
      color: rgba(255,255,255,.7);
      padding: clamp(60px, 8vw, 100px) 0 40px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: clamp(32px, 5vw, 64px);
      margin-bottom: 60px;
    }
    .footer-brand h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.55rem;
      color: #fff;
      margin-bottom: 12px;
    }
    .footer-brand p { font-size: .9rem; line-height: 1.85; margin-bottom: 24px; }
    .socials { display:flex; gap:10px; }
    .soc-btn {
      width: 38px; height: 38px;
      border-radius: 9px;
      background: rgba(255,255,255,.08);
      display:flex; align-items:center; justify-content:center;
      color: rgba(255,255,255,.65);
      font-size: .95rem;
      transition: background .2s, color .2s, transform .2s;
    }
    .soc-btn:hover {
      background: var(--accent);
      color: var(--dark);
      transform: translateY(-2px);
    }
    .footer-col h4 {
      font-size: .78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .09em;
      color: #fff;
      margin-bottom: 20px;
    }
    .footer-links { list-style: none; display:flex; flex-direction:column; gap:10px; }
    .footer-links a {
      color: rgba(255,255,255,.6);
      font-size: .88rem;
      transition: color .18s, padding-left .18s;
    }
    .footer-links a:hover { color: var(--accent-lt); padding-left: 5px; }
    .contact-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: .88rem;
      margin-bottom: 12px;
    }
    .contact-row i { color: var(--accent); margin-top: 3px; width:16px; flex-shrink:0; }
    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,.08);
      padding-top: 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      font-size: .82rem;
    }
    .footer-bottom a { color: rgba(255,255,255,.5); }
    .footer-bottom a:hover { color: var(--accent-lt); }

    /* ══════════════════════════════════════
       RESPONSIVE BREAKPOINTS
    ══════════════════════════════════════ */

    /* ── Tablet landscape & below (1024px) ── */
    @media (max-width: 1024px) {
      .about-grid {
        grid-template-columns: 1fr;
        max-width: 640px;
        margin: 0 auto;
      }
      .about-float { right: 16px; bottom: -16px; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }

    /* ── Tablet portrait & below (768px) ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }

      .hero-stats { gap: clamp(16px, 4vw, 36px); }

      /* 2-column cards on tablet */
      .cards-grid,
      .fac-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .gallery-grid { grid-template-columns: repeat(2, 1fr); }

      .footer-grid { grid-template-columns: 1fr; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }

    /* ── Mobile (480px) ── */
    @media (max-width: 480px) {
      .hero-content { padding-bottom: 140px; }

      .hero-btns {
        flex-direction: column;
        align-items: center;
      }
      .btn-gold, .btn-outline {
        width: 100%;
        max-width: 300px;
        justify-content: center;
      }

      /* Hide 3rd/4th stat on very small screens */
      .hero-stats .stat-item:nth-child(n+4) { display: none; }

      /* 1-column on phone */
      .cards-grid,
      .fac-grid,
      .gallery-grid {
        grid-template-columns: 1fr;
      }

      .about-float { display: none; }

      .ekstra-chip { font-size: .82rem; padding: 10px 18px; }
    }

    /* ── Small phones (360px) ── */
    @media (max-width: 360px) {
      .hero h1 { font-size: 2.2rem; }
      .hero-stats .stat-item:nth-child(n+3) { display: none; }
    }

    /* ══════════════════════════════════════
       NAVIGATION ENHANCEMENTS
    ══════════════════════════════════════ */

    /* Reading progress bar */
    #nav-progress {
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      width: 0%;
      background: linear-gradient(90deg, var(--primary), var(--sky), var(--accent));
      z-index: 2000;
      transition: width .08s linear;
      pointer-events: none;
    }

    /* Active nav link */
    .nav-links a.nav-active {
      color: var(--primary) !important;
      background: var(--bg-soft) !important;
    }

    /* Back to top */
    #back-to-top {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 990;
      width: 46px; height: 46px;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      box-shadow: 0 6px 24px rgba(26,58,110,.35);
      opacity: 0;
      transform: translateY(14px) scale(.9);
      transition: opacity .3s ease, transform .3s ease, background .2s ease;
      pointer-events: none;
    }
    #back-to-top.show {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }
    #back-to-top:hover {
      background: var(--primary-lt);
      transform: translateY(-3px) scale(1);
    }
    #back-to-top:active {
      transform: translateY(0) scale(.95);
    }

    /* Section dot navigator */
    #sec-nav {
      position: fixed;
      right: 20px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 980;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 10px 6px;
      background: rgba(255,255,255,.7);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-radius: 50px;
      border: 1px solid rgba(26,58,110,.08);
      box-shadow: var(--shadow-sm);
    }
    .sec-dot {
      position: relative;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: rgba(26,58,110,.2);
      cursor: pointer;
      border: none;
      padding: 0;
      transition: background .25s ease, transform .25s ease, height .25s ease, border-radius .25s ease;
      flex-shrink: 0;
    }
    .sec-dot:hover { background: var(--primary); transform: scale(1.3); }
    .sec-dot.active {
      background: var(--primary);
      height: 22px;
      border-radius: 4px;
      transform: none;
    }
    /* Tooltip label */
    .sec-dot::after {
      content: attr(data-label);
      position: absolute;
      right: calc(100% + 12px);
      top: 50%;
      transform: translateY(-50%);
      background: var(--dark);
      color: #fff;
      padding: 5px 11px;
      border-radius: 8px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: .72rem;
      font-weight: 600;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity .18s ease;
    }
    .sec-dot::before {
      content: '';
      position: absolute;
      right: calc(100% + 6px);
      top: 50%;
      transform: translateY(-50%);
      border: 5px solid transparent;
      border-left-color: var(--dark);
      opacity: 0;
      pointer-events: none;
      transition: opacity .18s ease;
    }
    .sec-dot:hover::after,
    .sec-dot:hover::before { opacity: 1; }

    @media (max-width: 900px) {
      #sec-nav { display: none; }
      #back-to-top { bottom: 20px; right: 20px; width: 42px; height: 42px; }
    }

    /* ══════════════════════════════════════
       HERO POLISH — floating badge glow
    ══════════════════════════════════════ */
    .hero-badge {
      box-shadow: 0 0 32px rgba(245,158,11,.18);
    }
    .hero h1 { text-shadow: 0 4px 32px rgba(0,0,0,.3); }

    /* ══════════════════════════════════════
       PASSWORD MODAL
    ══════════════════════════════════════ */
    #pwd-overlay {
      position: fixed; inset: 0;
      z-index: 2100;
      background: rgba(5,10,20,.82);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity .3s ease;
    }
    #pwd-overlay.show {
      opacity: 1;
      pointer-events: auto;
    }
    #pwd-box {
      background: #0d1117;
      border: 1px solid rgba(100,220,140,.2);
      border-radius: 16px;
      padding: 40px;
      width: min(420px, 90vw);
      box-shadow: 0 0 60px rgba(100,220,140,.1),
                  0 24px 80px rgba(0,0,0,.6);
      transform: translateY(18px) scale(.97);
      transition: transform .3s cubic-bezier(.22,1,.36,1);
      text-align: center;
    }
    #pwd-overlay.show #pwd-box {
      transform: translateY(0) scale(1);
    }
    #pwd-box .lock-icon {
      width: 64px; height: 64px;
      margin: 0 auto 20px;
      background: rgba(100,220,140,.08);
      border: 1px solid rgba(100,220,140,.2);
      border-radius: 50%;
      display: flex; align-items:center; justify-content:center;
      font-size: 1.5rem;
      color: rgba(100,220,140,.9);
      animation: pulse-lock 2s ease infinite;
    }
    @keyframes pulse-lock {
      0%,100% { box-shadow: 0 0 0 0 rgba(100,220,140,.25); }
      50%      { box-shadow: 0 0 0 10px rgba(100,220,140,0); }
    }
    #pwd-box h3 {
      font-family: 'Playfair Display', serif;
      color: rgba(100,220,140,.95);
      font-size: 1.25rem;
      margin-bottom: 6px;
    }
    #pwd-box p {
      color: rgba(255,255,255,.4);
      font-size: .82rem;
      margin-bottom: 28px;
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    #pwd-input {
      width: 100%;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(100,220,140,.2);
      border-radius: 10px;
      padding: 13px 18px;
      color: rgba(100,220,140,.9);
      font-family: 'Courier New', monospace;
      font-size: 1rem;
      letter-spacing: .12em;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      text-align: center;
    }
    #pwd-input::placeholder { color: rgba(100,220,140,.25); letter-spacing: .04em; }
    #pwd-input:focus {
      border-color: rgba(100,220,140,.55);
      box-shadow: 0 0 0 3px rgba(100,220,140,.08);
    }
    #pwd-error {
      color: #f87171;
      font-size: .78rem;
      margin-top: 10px;
      min-height: 18px;
      font-family: 'Courier New', monospace;
      transition: opacity .2s;
      opacity: 0;
    }
    #pwd-error.show { opacity: 1; }
    .pwd-btns {
      display: flex;
      gap: 10px;
      margin-top: 22px;
    }
    .pwd-btn-cancel {
      flex: 1;
      padding: 12px;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 9px;
      color: rgba(255,255,255,.5);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 600;
      font-size: .875rem;
      cursor: pointer;
      transition: all .2s;
    }
    .pwd-btn-cancel:hover { background: rgba(255,255,255,.08); color: rgba(255,255,255,.8); }
    .pwd-btn-enter {
      flex: 2;
      padding: 12px;
      background: rgba(100,220,140,.12);
      border: 1px solid rgba(100,220,140,.3);
      border-radius: 9px;
      color: rgba(100,220,140,.95);
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: .875rem;
      cursor: pointer;
      transition: all .2s;
    }
    .pwd-btn-enter:hover {
      background: rgba(100,220,140,.22);
      border-color: rgba(100,220,140,.55);
      box-shadow: 0 0 14px rgba(100,220,140,.2);
    }
    #pwd-box .shake { animation: shake .4s ease; }
    @keyframes shake {
      0%,100% { transform: translateX(0); }
      20%      { transform: translateX(-8px); }
      40%      { transform: translateX(8px); }
      60%      { transform: translateX(-6px); }
      80%      { transform: translateX(6px); }
    }

    /* ══════════════════════════════════════
       ADMIN PANEL
    ══════════════════════════════════════ */
    #admin-panel {
      position: fixed; inset: 0;
      z-index: 2200;
      background: #060d14;
      display: flex;
      flex-direction: column;
      opacity: 0;
      pointer-events: none;
      transform: translateY(12px);
      transition: opacity .35s ease, transform .35s cubic-bezier(.22,1,.36,1);
      overflow: hidden;
      font-family: 'Courier New', monospace;
    }
    #admin-panel.show {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    /* Scanlines effect */
    #admin-panel::before {
      content: '';
      position: absolute; inset: 0;
      background: repeating-linear-gradient(
        to bottom,
        transparent,
        transparent 2px,
        rgba(0,0,0,.06) 2px,
        rgba(0,0,0,.06) 4px
      );
      pointer-events: none;
      z-index: 1;
    }
    /* Subtle green glow vignette */
    #admin-panel::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center,
        rgba(100,220,140,.03) 0%,
        rgba(0,0,0,.35) 100%
      );
      pointer-events: none;
      z-index: 1;
    }

    /* Top bar */
    .admin-topbar {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 28px;
      border-bottom: 1px solid rgba(100,220,140,.12);
      background: rgba(100,220,140,.03);
    }
    .admin-topbar-left {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .tbar-dot {
      width: 12px; height: 12px;
      border-radius: 50%;
    }
    .tbar-dot.red   { background: #ff5f57; }
    .tbar-dot.yellow{ background: #febc2e; }
    .tbar-dot.green { background: #28c840; }
    .admin-topbar-title {
      color: rgba(100,220,140,.5);
      font-size: .75rem;
      letter-spacing: .12em;
      margin-left: 12px;
    }
    .admin-close-btn {
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.1);
      color: rgba(255,255,255,.5);
      border-radius: 8px;
      padding: 7px 16px;
      font-family: 'Courier New', monospace;
      font-size: .78rem;
      cursor: pointer;
      letter-spacing: .06em;
      transition: all .2s;
    }
    .admin-close-btn:hover {
      background: rgba(248,113,113,.12);
      border-color: rgba(248,113,113,.3);
      color: #f87171;
    }

    /* ASCII art header */
    .admin-ascii {
      position: relative;
      z-index: 10;
      text-align: center;
      padding: 28px 20px 12px;
      border-bottom: 1px solid rgba(100,220,140,.08);
    }
    .admin-ascii pre {
      display: inline-block;
      font-size: clamp(.28rem, 1vw, .52rem);
      line-height: 1.15;
      color: rgba(100,220,140,.85);
      text-shadow: 0 0 10px rgba(100,220,140,.4);
      white-space: pre;
      overflow: visible;
      font-family: 'Courier New', monospace;
    }
    .admin-ascii .version-tag {
      display: inline-block;
      margin-top: 8px;
      background: rgba(100,220,140,.1);
      border: 1px solid rgba(100,220,140,.2);
      color: rgba(100,220,140,.7);
      padding: 3px 14px;
      border-radius: 50px;
      font-size: .68rem;
      letter-spacing: .12em;
    }

    /* Main content */
    .admin-body {
      position: relative;
      z-index: 10;
      flex: 1;
      overflow-y: auto;
      padding: 24px 28px 28px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 320px), 1fr));
      gap: 18px;
      align-content: start;
    }
    .admin-body::-webkit-scrollbar { width: 4px; }
    .admin-body::-webkit-scrollbar-track { background: transparent; }
    .admin-body::-webkit-scrollbar-thumb { background: rgba(100,220,140,.2); border-radius: 2px; }

    /* Widgets */
    .admin-widget {
      background: rgba(100,220,140,.035);
      border: 1px solid rgba(100,220,140,.13);
      border-radius: 12px;
      padding: 22px;
      transition: border-color .2s, box-shadow .2s;
    }
    .admin-widget:hover {
      border-color: rgba(100,220,140,.3);
      box-shadow: 0 0 20px rgba(100,220,140,.06);
    }
    .admin-widget h4 {
      color: rgba(100,220,140,.9);
      font-size: .72rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      border-bottom: 1px solid rgba(100,220,140,.1);
      padding-bottom: 10px;
    }
    .admin-widget h4 i { opacity: .7; }

    /* Stats in admin */
    .admin-stats-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .admin-stat-box {
      background: rgba(100,220,140,.05);
      border: 1px solid rgba(100,220,140,.1);
      border-radius: 8px;
      padding: 14px;
      text-align: center;
    }
    .admin-stat-num {
      font-size: 1.7rem;
      font-weight: bold;
      color: rgba(100,220,140,.95);
      line-height: 1;
      text-shadow: 0 0 16px rgba(100,220,140,.4);
    }
    .admin-stat-lbl {
      font-size: .62rem;
      color: rgba(100,220,140,.45);
      letter-spacing: .1em;
      margin-top: 5px;
      text-transform: uppercase;
    }

    /* Announcement form */
    .admin-field {
      width: 100%;
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(100,220,140,.15);
      border-radius: 8px;
      padding: 10px 14px;
      color: rgba(200,255,220,.8);
      font-family: 'Courier New', monospace;
      font-size: .82rem;
      outline: none;
      resize: none;
      transition: border-color .2s;
      margin-bottom: 10px;
    }
    .admin-field::placeholder { color: rgba(100,220,140,.2); }
    .admin-field:focus { border-color: rgba(100,220,140,.4); }
    .admin-btn {
      background: rgba(100,220,140,.12);
      border: 1px solid rgba(100,220,140,.3);
      color: rgba(100,220,140,.9);
      border-radius: 8px;
      padding: 9px 20px;
      font-family: 'Courier New', monospace;
      font-size: .8rem;
      cursor: pointer;
      letter-spacing: .06em;
      transition: all .2s;
    }
    .admin-btn:hover {
      background: rgba(100,220,140,.22);
      box-shadow: 0 0 12px rgba(100,220,140,.2);
    }
    .admin-btn.danger {
      background: rgba(248,113,113,.08);
      border-color: rgba(248,113,113,.25);
      color: #f87171;
    }
    .admin-btn.danger:hover { background: rgba(248,113,113,.18); }

    /* Announcement list */
    #ann-list { display: flex; flex-direction: column; gap: 8px; }
    .ann-item {
      background: rgba(100,220,140,.04);
      border: 1px solid rgba(100,220,140,.1);
      border-radius: 7px;
      padding: 10px 14px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }
    .ann-item-text { color: rgba(200,255,220,.7); font-size: .8rem; line-height: 1.5; flex: 1; }
    .ann-item-del {
      background: none;
      border: none;
      color: rgba(248,113,113,.5);
      cursor: pointer;
      font-size: .75rem;
      padding: 2px 6px;
      border-radius: 4px;
      transition: all .15s;
      flex-shrink: 0;
    }
