    /* ══════════════════════════════════════
       PROGRAM CARDS — GLASSMORPHISM UPGRADE
    ══════════════════════════════════════ */
    .prog-card {
      background: linear-gradient(145deg, #fff 0%, var(--bg-soft) 100%);
      border-top: none;
      transition: transform .3s cubic-bezier(.22,1,.36,1),
                  box-shadow .3s cubic-bezier(.22,1,.36,1),
                  background .3s ease;
    }
    .prog-card:hover {
      background: linear-gradient(145deg, #fff 0%, rgba(14,165,233,.06) 100%);
    }
    .prog-card::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: var(--r);
      padding: 1px;
      background: linear-gradient(135deg, rgba(14,165,233,.18), transparent 60%);
      -webkit-mas: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity .3s ease;
    }
    .prog-card:hover::before { opacity: 1; }

    /* ══════════════════════════════════════
       FACILITY CARDS UPGRADE
    ══════════════════════════════════════ */
    .fac-card {
      background: linear-gradient(135deg, #fff 0%, var(--bg-soft) 100%);
      border-left: 3px solid transparent;
      transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }
    .fac-card:hover {
      border-left-color: var(--sky);
    }

    /* ══════════════════════════════════════
       TESTIMONIAL UPGRADE
    ══════════════════════════════════════ */
